---
layout: layouts/base.njk
---
<article class="chapter">
  <header class="chapter__header">
    {% if part %}<p class="chapter__kicker">{{ part }}</p>{% endif %}
    <h1 class="chapter__title">{{ title }}</h1>
  </header>

  <div class="chapter__body">
    {{ content | safe }}
  </div>

  {% include "components/nav.njk" %}
</article>
