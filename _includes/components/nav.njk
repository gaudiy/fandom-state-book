{# 同一言語の章コレクションから前後リンクを生成する #}
{% set chapters = collections.chaptersJa if lang == "ja" else collections.chaptersEn %}
{% set prev = chapters | getPreviousCollectionItem %}
{% set next = chapters | getNextCollectionItem %}

<nav class="chapter-nav" aria-label="章ナビゲーション">
  <div class="chapter-nav__prev">
    {% if prev %}
      <a href="{{ prev.url }}">← {{ prev.data.title }}</a>
    {% endif %}
  </div>
  <div class="chapter-nav__index">
    <a href="{{ '/ja/' if lang == 'ja' else '/en/' }}">目次</a>
  </div>
  <div class="chapter-nav__next">
    {% if next %}
      <a href="{{ next.url }}">{{ next.data.title }} →</a>
    {% endif %}
  </div>
</nav>
