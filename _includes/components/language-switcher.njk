<nav class="lang-switcher" aria-label="言語切り替え">
  {%- for l in site.languages %}
    {%- if not loop.first %}<span class="lang-switcher__sep">/</span>{% endif %}
    <a
      class="lang-switcher__item{% if l.code == lang %} is-active{% endif %}"
      href="{{ l.home }}"
      hreflang="{{ l.code }}"
    >{{ l.short }}</a>
  {%- endfor %}
</nav>
